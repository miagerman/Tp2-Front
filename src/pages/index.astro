---
import Footer from "../components/Footer.astro";
---

<style>
  @import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Inter:wght@400;500;600&display=swap');

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg: #f5f3ef;
    --card: #ffffff;
    --text: #171717;
    --muted: #6f6f78;
    --primary: #5b5cf0;
    --border: #e8e5df;
  }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--text);
  }

  .landing {
    overflow-x: hidden;
  }

  /* NAV */

  .nav {
    width: 100%;
    padding: 22px 7%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-family: 'Syne', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
  }

  .logo span {
    color: var(--primary);
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--muted);
    font-size: 0.95rem;
    transition: 0.2s;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .nav-btn {
    background: var(--text);
    color: white;
    text-decoration: none;
    padding: 0.9rem 1.4rem;
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 500;
  }

  /* HERO */

  .hero {
    min-height: 88vh;
    padding: 5rem 7%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    background: white;
    border: 1px solid #d9d8ff;
    color: var(--primary);
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 1.8rem;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--primary);
  }

  .hero h1 {
    font-family: 'Syne', sans-serif;
    font-size: 5rem;
    line-height: 0.95;
    margin-bottom: 1.5rem;
  }

  .hero h1 span {
    color: var(--primary);
  }

  .hero p {
    max-width: 520px;
    color: var(--muted);
    line-height: 1.7;
    font-size: 1rem;
    margin-bottom: 2rem;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .primary-btn {
    text-decoration: none;
    padding: 1rem 1.5rem;
    border-radius: 14px;
    font-size: 0.95rem;
    font-weight: 500;
    background: var(--text);
    color: white;
    transition: 0.2s;
  }

  .primary-btn:hover {
    transform: translateY(-2px);
  }

  /* CARD */

  .preview {
    background: var(--card);
    border-radius: 28px;
    padding: 2rem;
    border: 1px solid var(--border);
    box-shadow: 0 20px 50px rgba(0,0,0,0.06);
  }

  .preview-top {
    display: flex;
    justify-content: space-between;
    margin-bottom: 2rem;
  }

  .preview-title {
    font-weight: 600;
  }

  .preview-date {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .tasks {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .task {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #faf9f7;
    border: 1px solid var(--border);
    padding: 1rem;
    border-radius: 16px;
  }

  .task-left {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .check {
    width: 18px;
    height: 18px;
    border-radius: 999px;
    border: 2px solid #cfcfd7;
  }

  .done {
    background: var(--primary);
    border-color: var(--primary);
  }

  .task-name {
    font-size: 0.95rem;
  }

  .badge {
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .design {
    background: #ecebff;
    color: var(--primary);
  }

  .dev {
    background: #dff8eb;
    color: #0e8a55;
  }

  /* FEATURES */

  .features {
    padding: 6rem 7%;
  }

  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .section-sub {
    color: var(--muted);
    max-width: 580px;
    line-height: 1.7;
  }

  .feature-grid {
    margin-top: 4rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    background: white;
    padding: 2rem;
    border-radius: 24px;
    border: 1px solid var(--border);
  }

  .feature-card h3 {
    margin: 1rem 0;
    font-size: 1.1rem;
  }

  .feature-card p {
    color: var(--muted);
    line-height: 1.6;
    font-size: 0.95rem;
  }

  /* CTA */

  .cta {
    margin: 0 7% 5rem;
    background: #18181f;
    border-radius: 32px;
    padding: 5rem;
    text-align: center;
  }

  .cta h2 {
    color: white;
    font-family: 'Syne', sans-serif;
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .cta p {
    color: #b9b9c2;
    margin-bottom: 2rem;
  }

  .cta a {
    display: inline-block;
    text-decoration: none;
    background: var(--primary);
    color: white;
    padding: 1rem 1.6rem;
    border-radius: 14px;
    font-weight: 500;
  }

  /* RESPONSIVE */

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .hero h1 {
      font-size: 3.5rem;
    }

    .feature-grid {
      grid-template-columns: 1fr;
    }

    .nav-links {
      display: none;
    }

    .cta {
      padding: 3rem 2rem;
    }

    .cta h2 {
      font-size: 2rem;
    }
  }
</style>

<div class="landing">

  <nav class="nav">
    <div class="logo">Task<span>ly</span></div>

    <ul class="nav-links">
      <li><a href="/about">About us</a></li>
  
    </ul>

    <a href="#" class="nav-btn">Comenzar</a>
  </nav>

  <section class="hero">

    <div>
      <div class="tag">
        <div class="dot"></div>
        Simple -  Rapido -  Sin vueltas
      </div>

      <h1>
        Organiza tu equipo <span>sin perder tiempo.</span>
      </h1>

      <p>
        Taskly junta tareas, proyectos y comunicacion en un solo lugar.
        Menos reuniones, menos caos y mas trabajo hecho.
      </p>

      <div class="hero-buttons">
        <a href="#" class="primary-btn">Comenzar</a>
      </div>
    </div>

    <div class="preview">

      <div class="preview-top">
        <div class="preview-title">Mi semana</div>
        <div class="preview-date">Mayo 2026</div>
      </div>

      <div class="tasks">

        <div class="task">
          <div class="task-left">
            <div class="check done"></div>
            <div class="task-name">Landing terminada</div>
          </div>

          <div class="badge design">Design</div>
        </div>

        <div class="task">
          <div class="task-left">
            <div class="check done"></div>
            <div class="task-name">Deploy del proyecto</div>
          </div>

          <div class="badge dev">Dev</div>
        </div>

        <div class="task">
          <div class="task-left">
            <div class="check"></div>
            <div class="task-name">Testing mobile</div>
          </div>

          <div class="badge design">UI</div>
        </div>

      </div>

    </div>

  </section>

  <section class="features">

    <h2 class="section-title">
      Todo mas claro.
    </h2>

    <p class="section-sub">
      Organiza tareas, segui proyectos y trabaja con tu equipo sin herramientas innecesarias.
    </p>

    <div class="feature-grid">

      <div class="feature-card">
        <h3>Boards visuales</h3>
        <p>
          Arrastra tareas entre columnas y segui el progreso en tiempo real.
        </p>
      </div>

      <div class="feature-card">
        <h3>Trabajo en equipo</h3>
        <p>
          Comparti proyectos y mante todo sincronizado desde cualquier lugar.
        </p>
      </div>

      <div class="feature-card">
        <h3>Recordatorios</h3>
        <p>
          Fechas limite, alertas y seguimiento automatico para no olvidarte de nada.
        </p>
      </div>

    </div>

  </section>

  <section class="cta">

    <h2>
      Empeza hoy.
    </h2>

    <p>
      Gratis, rapido y sin configuraciones complicadas.
    </p>

    <a href="#">Crear cuenta</a>

  </section>

  <Footer />

</div>