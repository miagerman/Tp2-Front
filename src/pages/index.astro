---
import '../styles/global.css'
import '../styles/home.css'
---

<main class="landing">
  <div class="background-glow"></div>

  <section class="hero-card">
    <p class="mini-title">
      ✦ SERVERLESS PRODUCTIVITY APP
    </p>

    <h1 class="hero-title">
      Task<span>ly</span>
    </h1>

    <p class="hero-description">
      Organiza tus tareas, gestioná proyectos y accedé desde cualquier lugar
      con una experiencia moderna y minimalista.
    </p>

    <div class="hero-buttons">
      <a href="/register" class="hero-primary">
        Empezar gratis
      </a>

      <a href="/login" class="hero-secondary">
        Iniciar sesión
      </a>
    </div>

    <div class="hero-stats">
      <div class="stat">
        <h3>10K+</h3>
        <p>Tareas creadas</p>
      </div>

      <div class="stat">
        <h3>99.9%</h3>
        <p>Disponibilidad</p>
      </div>

      <div class="stat">
        <h3>24/7</h3>
        <p>Acceso cloud</p>
      </div>
    </div>
  </section>
</main>